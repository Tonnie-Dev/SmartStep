<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/imgHeaderIcon"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_sneakers"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/txtTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Smart Step Counter"
            android:textSize="14sp"
            android:textColor="#6C6E71" />

        <TextView
            android:id="@+id/txtDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="•"
            android:textSize="14sp"
            android:textColor="#6C6E71" />

        <TextView
            android:id="@+id/txtTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="2m"
            android:textSize="14sp"
            android:textColor="#6C6E71" />

        <ImageView
            android:id="@+id/imgChevronUp"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:src="@drawable/ic_chevron_up"
            android:contentDescription="@null"
            android:scaleType="centerInside"
            android:adjustViewBounds="true" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgSteps"
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:contentDescription="@null"
                android:src="@drawable/ic_sneakers" />

            <TextView
                android:id="@+id/txtSteps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="7,842"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1F2024" />
        </LinearLayout>

        <ImageView
            android:layout_width="1dp"
            android:layout_height="24dp"
            android:background="#E5E7EB"
            android:src="@android:color/transparent"
            android:contentDescription="@null" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgCalories"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_weight"
                android:contentDescription="@null" />

            <TextView
                android:id="@+id/txtCalories"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:text="342"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#1F2024" />
        </LinearLayout>

        <ImageView
            android:id="@+id/imgChevronRight"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginStart="12dp"
            android:src="@drawable/ic_notification_circle_arrow"
            android:contentDescription="@null" />
    </LinearLayout>

    <ProgressBar
        android:id="@+id/progressSteps"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="8dp"
        android:layout_marginTop="16dp"
        android:max="10000"
        android:progress="2500"
        android:progressTint="@color/purple_500"
        android:progressBackgroundTint="#E7E8F5" />
</LinearLayout>